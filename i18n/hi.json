  "app_name": "WealthX",
  "card_accounts_desc": "टैप करके खाता विवरण, चलती शेष राशि इतिहास और संपत्ति/देनदारियाँ देखें।",
  "card_accounts_title": "खाते",
  "card_budgets_desc": "Smart Budget योजनाओं, अनुकूलित सीमाओं और लक्ष्य-लिंक्ड मासिक दृश्यों को देखने के लिए टैप करें.",
  "card_budgets_title": "बजट",
  "card_flows_desc": "टैप करके पुन: उपयोग योग्य टेम्पलेट, नियोजित शेड्यूल और त्वरित‑प्रविष्टि मार्ग देखें।",
  "card_flows_title": "Flows",
  "card_insights_desc": "टैप करके रुझान, विभाजन दृश्य और कैशफ्लो मैप देखें।",
  "card_insights_title": "इनसाइट्स",
  "details_accounts_desc": "WealthX में खाते केवल एक सूची नहीं हैं। आप संपत्ति और देनदारियों को अलग कर सकते हैं, संबंधित खातों को समूहित कर सकते हैं, और हर खाते के लेजर में गहराई से जा सकते हैं।",
  "details_accounts_image_alt": "WealthX खाता प्रबंधन स्क्रीन",
  "details_accounts_point1": "अपनी नेट स्थिति स्पष्ट रखने के लिए संपत्ति और देनदारी के दृश्य के बीच स्विच करें।",
  "details_accounts_point2": "खाते का विवरण खोलें और लेन‑देन व चलती शेष राशि देखें।",
  "details_accounts_point3": "विवरण स्क्रीन से सीधे लेन‑देन जोड़ें या संपादित करें, जैसे ट्रांसफर और रिफंड।",
  "details_accounts_title": "खाते: संरचना + लेजर",
  "details_budgets_desc": "मासिक बजट बनाएं, उन्हें लक्ष्यों से जोड़ें, और हर माइलस्टोन को तुरंत अपडेट के साथ ट्रैक करें.",
  "details_budgets_image_alt": "WealthX बजट योजना स्क्रीन",
  "details_budgets_point1": "खर्च के पैटर्न और आवर्ती लेनदेन के आधार पर Smart Budget सुझाव पाएं.",
  "details_budgets_point2": "प्रत्येक बजट को लक्ष्यों से लिंक करें और अनुमानित पूरा होने की तिथियाँ स्वचालित रूप से देखें.",
  "details_budgets_point3": "प्रगति रिंग्स, माइलस्टोन इतिहास और लक्ष्य समायोजन सुझाव देखने के लिए विवरण खोलें.",
  "details_budgets_title": "Smart Budget + Goal Tracker",
  "details_flows_desc": "Flows आपको सामान्य लेन‑देन को टेम्पलेट के रूप में सहेजने और रोज़ाना बही‑खाते में तेज़ी से चलाने देते हैं।",
  "details_flows_image_alt": "WealthX Flows शॉर्टकट स्क्रीन",
  "details_flows_point1": "खाते और बजट बाइंडिंग के साथ खर्च, आय और ट्रांसफर टेम्पलेट बनाएं।",
  "details_flows_point2": "साप्ताहिक, द्विसाप्ताहिक या मासिक पुनरावृत्ति और रिमाइंडर समय के साथ नियोजित Flows सक्षम करें।",
  "details_flows_point3": "दोहराए जाने वाले इनपुट कम करने के लिए Today शॉर्टकट, विजेट और स्मार्ट सुझावों का उपयोग करें।",
  "details_flows_title": "Flows: पुन: प्रयोग योग्य और अनुसूचित",
  "details_insights_desc": "स्टैटिस्टिक्स मॉड्यूल ओवरव्यू और गहन चार्ट को मिलाता है ताकि आप विचलन जल्दी पकड़ सकें।",
  "details_insights_image_alt": "WealthX इंसाइट्स और कैशफ्लो मैप स्क्रीन",
  "details_insights_point1": "सारांश, खाता विभाजन, बजट विभाजन, नेट वर्थ रुझान और कैशफ्लो रुझान देखें।",
  "details_insights_point2": "आपके लिए महत्वपूर्ण संकेत अलग करने के लिए समय सीमा और मुद्रा सेट से फ़िल्टर करें।",
  "details_insights_point3": "जब उपलब्ध हो तो स्थान‑सम्बंधित खर्च के पैटर्न के लिए कैशफ्लो मैप खोलें।",
  "details_insights_title": "इंसाइट्स: सारांश से कैशफ्लो मैप तक",
  "details_subtitle": "हर कार्ड सीधे संबंधित मॉड्यूल पर जाता है ताकि आप डाउनलोड करने से पहले असली वर्कफ़्लो देख सकें।",
  "details_title": "विशेषताओं का विवरण",
  "features_subtitle": "एक स्पष्ट वित्तीय संरचना बनाएं, फिर हर मॉड्यूल को गहराई से देखें।",
